// ============================================================
// Teensy 4.1 Solenoid Voltage Logger
// ============================================================
//
// PURPOSE:
// This program reads an analog voltage signal (for example,
// from a solenoid measurement circuit), converts the raw ADC
// reading into a voltage, and saves the data to a CSV file
// on the Teensy 4.1's built-in microSD card.
//
// CSV FORMAT:
// time_us, raw_adc, measured_voltage_V, actual_voltage_V
//
// Example row:
// 0,512,1.6500,3.3000
//
// NOTES:
// - The Teensy analog input pin should only see 0 to 3.3 V.
// - If the real signal is larger, use scaling hardware
//   (like a voltage divider) and adjust SIGNAL_SCALE_FACTOR.
// ============================================================

#include <Arduino.h>   // Core Arduino functions like setup(), loop(), Serial, analogRead()
#include <SD.h>        // SD card file access
#include <SPI.h>       // SPI communication (used by SD library internally)


// ------------------------------------------------------------
// Configuration
// ------------------------------------------------------------

// Analog input pin where the signal is connected.
// A0 is a common analog input pin on Teensy boards.
const int ANALOG_PIN = A0;

// Time between samples, in microseconds.
// 1000 us = 1 ms = 1000 samples per second.
const unsigned long SAMPLE_INTERVAL_US = 1000;

// Reference voltage for the ADC.
// Teensy 4.1 analog inputs typically measure from 0 to 3.3 V.
const float ADC_REFERENCE_VOLTAGE = 3.3f;

// Maximum ADC value for 10-bit resolution.
// Since 10-bit ADC gives values from 0 to 1023:
const int ADC_MAX_COUNT = 1023;

// Scaling factor used to reconstruct the actual signal voltage.
// Example:
// If the signal is divided by 2 before entering the Teensy,
// then set this to 2.0 so the program reports the original voltage.
//
// If the Teensy reads the true voltage directly, keep this at 1.0.
const float SIGNAL_SCALE_FACTOR = 1.0f;

// Name of the file on the microSD card.
// CSV format is useful because it opens easily in Excel, MATLAB, Python, etc.
const char *LOG_FILE_NAME = "SOLENOID.CSV";

// If true, each logged sample is also printed to the Serial Monitor.
// Useful for debugging, but can slow things down at high sample rates.
const bool PRINT_TO_SERIAL = true;

// If true, the file is flushed after every sample.
// This is safer if power is lost suddenly, but it makes logging slower.
// If false, the file is flushed every 100 samples instead.
const bool FLUSH_EVERY_SAMPLE = false;


// ------------------------------------------------------------
// Global State
// ------------------------------------------------------------

// File object representing the open SD card file.
File logFile;

// Tracks when the next sample should be taken.
unsigned long nextSampleTimeUs = 0;

// Stores the time when logging began.
// This allows us to log elapsed time instead of absolute micros().
unsigned long startTimeUs = 0;

// Counts how many samples have been collected.
unsigned long sampleCount = 0;


// ------------------------------------------------------------
// Function Declarations
// ------------------------------------------------------------

// Initializes the SD card hardware.
bool initializeSDCard();

// Opens the output CSV file on the SD card.
bool openLogFile();

// Writes the CSV header row to the file.
void writeHeader();

// Takes one sample and writes it to the file.
void logOneSample();

// Converts raw ADC count (0–1023) into measured voltage at the Teensy pin.
float convertADCToMeasuredVoltage(int rawADC);

// Applies the scaling factor to estimate the true voltage of the original signal.
float convertMeasuredToActualVoltage(float measuredVoltage);


// ------------------------------------------------------------
// Setup
// ------------------------------------------------------------

void setup()
{
  // Start Serial communication so messages can be viewed
  // in the Arduino IDE Serial Monitor.
  Serial.begin(115200);

  // Short delay to give the Serial Monitor time to connect.
  delay(1500);

  Serial.println("\n=== Solenoid Logger Starting ===");

  // Set analogRead() to 10-bit resolution.
  // This means analogRead() returns values between 0 and 1023.
  analogReadResolution(10);

  // Average multiple ADC readings together to reduce noise.
  // Higher averaging can make readings cleaner, but slightly slower.
  analogReadAveraging(4);

  // Set the analog pin as an input.
  pinMode(ANALOG_PIN, INPUT);

  // Initialize the built-in SD card.
  if (!initializeSDCard())
  {
    Serial.println("SD init failed. Stopping.");

    // Stop forever if the SD card cannot be initialized.
    while (true) delay(1000);
  }

  // Open the output log file.
  if (!openLogFile())
  {
    Serial.println("File open failed. Stopping.");

    // Stop forever if the file cannot be opened.
    while (true) delay(1000);
  }

  // Write the CSV header row.
  writeHeader();

  // Record the start time.
  startTimeUs = micros();

  // Schedule the first sample immediately.
  nextSampleTimeUs = startTimeUs;

  Serial.println("Logging started.\n");
}


// ------------------------------------------------------------
// Main Loop
// ------------------------------------------------------------

void loop()
{
  // Current time in microseconds since the board started running.
  unsigned long now = micros();

  // Check whether it's time to take the next sample.
  //
  // This signed subtraction trick is commonly used so the code
  // still works correctly even when micros() eventually rolls over.
  if ((long)(now - nextSampleTimeUs) >= 0)
  {
    // Take and store one sample.
    logOneSample();

    // Schedule the next sample.
    // Using += keeps the timing more regular than resetting from micros().
    nextSampleTimeUs += SAMPLE_INTERVAL_US;
  }
}


// ------------------------------------------------------------
// SD Card Handling
// ------------------------------------------------------------

bool initializeSDCard()
{
  Serial.println("Initializing SD...");

  // BUILTIN_SDCARD is the proper option for Teensy 4.1's
  // built-in microSD slot.
  if (!SD.begin(BUILTIN_SDCARD)) return false;

  Serial.println("SD ready.");
  return true;
}

bool openLogFile()
{
  Serial.println("Opening file...");

  // FILE_WRITE opens the file for writing.
  // If the file already exists, new data is appended at the end.
  // If it does not exist, the file is created.
  logFile = SD.open(LOG_FILE_NAME, FILE_WRITE);

  if (!logFile) return false;

  Serial.println("File ready.");
  return true;
}


// ------------------------------------------------------------
// Logging
// ------------------------------------------------------------

void writeHeader()
{
  // Add a blank line between logging runs in case data is appended
  // to an existing file from a previous test.
  logFile.println();

  // Simple session marker for readability.
  logFile.println("=== New Session ===");

  // CSV column headers.
  logFile.println("time_us,raw_adc,measured_voltage_V,actual_voltage_V");

  // Immediately write the header to the card.
  logFile.flush();

  // Optionally print the header to the Serial Monitor too.
  if (PRINT_TO_SERIAL)
  {
    Serial.println("time_us,raw_adc,measured_voltage_V,actual_voltage_V");
  }
}

void logOneSample()
{
  // Read the analog input pin.
  // Since resolution is 10-bit, the result is from 0 to 1023.
  int rawADC = analogRead(ANALOG_PIN);

  // Compute how much time has passed since logging started.
  unsigned long elapsed = micros() - startTimeUs;

  // Convert the raw ADC count to the voltage seen by the Teensy pin.
  float measured = convertADCToMeasuredVoltage(rawADC);

  // Scale the measured voltage back to the estimated real signal voltage.
  float actual = convertMeasuredToActualVoltage(measured);

  // Write one line to the CSV file.
  logFile.print(elapsed);
  logFile.print(",");
  logFile.print(rawADC);
  logFile.print(",");
  logFile.print(measured, 4);
  logFile.print(",");
  logFile.println(actual, 4);

  // Optionally print the same line to the Serial Monitor.
  if (PRINT_TO_SERIAL)
  {
    Serial.print(elapsed); Serial.print(",");
    Serial.print(rawADC); Serial.print(",");
    Serial.print(measured, 4); Serial.print(",");
    Serial.println(actual, 4);
  }

  // If enabled, force every sample to be written to the SD card immediately.
  if (FLUSH_EVERY_SAMPLE)
  {
    logFile.flush();
  }

  // Increase the sample counter.
  sampleCount++;

  // If not flushing every sample, flush every 100 samples instead.
  // This improves speed while still periodically protecting data.
  if (!FLUSH_EVERY_SAMPLE && (sampleCount % 100 == 0))
  {
    logFile.flush();
  }
}


// ------------------------------------------------------------
// Conversions
// ------------------------------------------------------------

float convertADCToMeasuredVoltage(int rawADC)
{
  // Converts ADC count to voltage:
  //
  // measured voltage = (raw ADC / max ADC count) * reference voltage
  //
  // Example:
  // rawADC = 512
  // measured = (512 / 1023) * 3.3 ≈ 1.65 V
  return ((float)rawADC / ADC_MAX_COUNT) * ADC_REFERENCE_VOLTAGE;
}

float convertMeasuredToActualVoltage(float measuredVoltage)
{
  // Applies the scaling factor to reconstruct the original signal voltage.
  //
  // Example:
  // measuredVoltage = 1.65 V
  // SIGNAL_SCALE_FACTOR = 2.0
  // actual = 3.30 V
  return measuredVoltage * SIGNAL_SCALE_FACTOR;
}
